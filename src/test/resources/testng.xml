<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Selenium Grid Test Suite" parallel="tests" thread-count="4">
    <!-- 监听器配置 -->
    <listeners>
        <listener class-name="org.zhengjiale.listener.TestListener"/>
        <listener class-name="org.zhengjiale.listener.RetryAnnotationTransformer"/>
    </listeners>

    <!-- 参数配置 -->
    <parameter name="browser" value="chrome"/>

    <!-- ==================== 本地测试 ==================== -->
    <test name="Local Chrome Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="org.zhengjiale.tests.SeleniumDevTest"/>
            <class name="org.zhengjiale.tests.BingSearchTest"/>
            <class name="org.zhengjiale.tests.GitHubTest"/>
        </classes>
    </test>

    <!-- ==================== 分布式测试（启用 Grid 时使用） ==================== -->
